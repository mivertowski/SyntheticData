# DataSynth Server Environment Configuration
# Copy to /etc/datasynth/server.env and customize

# Logging level (trace, debug, info, warn, error)
RUST_LOG=info

# API authentication (comma-separated keys)
# DATASYNTH_API_KEYS=key1,key2,key3

# Worker threads (0 = auto-detect from CPU count)
# DATASYNTH_WORKER_THREADS=0

# TLS (requires --features tls)
# DATASYNTH_TLS_CERT=/etc/datasynth/tls/cert.pem
# DATASYNTH_TLS_KEY=/etc/datasynth/tls/key.pem

# OpenTelemetry (requires --features otel)
# OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4317
# OTEL_SERVICE_NAME=datasynth-server
