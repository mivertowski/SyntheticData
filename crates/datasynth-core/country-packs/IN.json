        { "up_to": 1200000, "rate": 0.15 },
        { "up_to": 1500000, "rate": 0.20 },
        { "above": 1500000, "rate": 0.30 }
      ],
      "social_security": {
        "pension": { "employee_rate": 0.12, "employer_rate": 0.12, "ceiling_annual": 180000 },
        "health": { "employee_rate": 0.0075, "employer_rate": 0.0325, "ceiling_annual": 252000 },
        "unemployment": { "employee_rate": 0.0, "employer_rate": 0.0, "ceiling_annual": null },
