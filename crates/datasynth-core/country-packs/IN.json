  "payroll": {
    "pay_frequency": "monthly",
    "currency": "INR",
    "statutory_deductions": [
      { "code": "IT", "name": "Income Tax", "name_en": "Income Tax", "type": "progressive", "rate": 0.0 },
      { "code": "PF", "name": "Provident Fund", "name_en": "Employee Provident Fund", "type": "percentage", "rate": 0.12 },
