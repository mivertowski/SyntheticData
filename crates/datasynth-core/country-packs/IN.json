  "tax": {
    "corporate_income_tax": {
      "standard_rate": 0.2517,
      "trade_tax_rate": 0.0,
      "solidarity_surcharge": 0.04,
      "effective_combined_rate": 0.2517,
      "small_business_threshold": 4000000
    },
    "vat": {
      "standard_rate": 0.18,
      "reduced_rates": [
        { "rate": 0.12, "label": "standard_goods", "applies_to": ["processed_food", "computers", "telecom"] },
        { "rate": 0.05, "label": "essential", "applies_to": ["transport", "basic_food", "healthcare"] },
        { "rate": 0.0, "label": "nil", "applies_to": ["fresh_food", "books", "education"] }
      ],
      "zero_rated": ["exports", "sez_supplies"],
      "exempt": ["healthcare_services", "education_services", "agriculture"],
      "registration_threshold": 4000000,
      "filing_frequency": "monthly",
      "reverse_charge_applicable": true
