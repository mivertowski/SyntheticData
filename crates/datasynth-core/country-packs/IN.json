  "address": {
    "format_template": "{building_number}, {street}\n{city}, {state} {postal_code}",
    "components": {
      "street_names": [
        "MG Road", "Station Road", "Gandhi Nagar", "Nehru Place", "Industrial Area",
        "IT Park Road", "Ring Road", "Main Street", "Sector 5", "Rajaji Nagar"
      ],
      "city_names": [
        "Mumbai", "Delhi", "Bangalore", "Hyderabad", "Chennai", "Kolkata",
        "Pune", "Ahmedabad", "Jaipur", "Lucknow"
      ],
      "state_names": [
        "Maharashtra", "Delhi", "Karnataka", "Telangana", "Tamil Nadu",
        "West Bengal", "Gujarat", "Rajasthan"
      ],
      "state_codes": ["MH", "DL", "KA", "TS", "TN", "WB", "GJ", "RJ"]
    },
    "postal_code": {
      "format": "NNNNNN",
      "regex": "^[1-9][0-9]{5}$",
      "ranges": [{ "from": "110001", "to": "855117" }]
    },
    "building_number": {
      "format": "alphanumeric",
      "range": [1, 500]
    },
    "country_calling_code": "+91"
  },

  "phone": {
    "country_calling_code": "+91",
    "formats": {
      "landline": "+91-{area_code}-{n7}",
      "mobile": "+91-{n5}-{n5}",
      "freephone": "+91-1800-{n3}-{n4}"
    },
    "area_codes": ["11", "22", "80", "40", "44", "33", "20", "79", "141", "522"],
    "subscriber_length": { "min": 7, "max": 8 },
    "display_format": "+91 {n5} {n5}"
  },

  "banking": {
    "account_format": "domestic",
