  "business_rules": {
    "invoice": {
      "numbering_format": "INV/{FY}-{SEQ:6}",
      "mandatory_fields": ["gstin", "hsn_code", "place_of_supply", "tax_breakup"],
      "retention_years": 8,
      "electronic_invoice_mandatory": true,
      "e_invoice_format": "GST_E_Invoice"
    },
    "payment_terms": {
      "default_days": 30,
      "common_terms": [15, 30, 45, 60, 90],
      "early_payment_discount": { "common_rate": 0.02, "common_days": 10 },
      "late_payment_interest": { "statutory_rate": 0.18, "base_rate_reference": "RBI" }
    },
    "approval_thresholds": {
      "currency": "INR",
      "levels": [
        { "up_to": 100000, "approver": "team_lead" },
        { "up_to": 1000000, "approver": "department_head" },
        { "up_to": 10000000, "approver": "director" },
        { "above": 10000000, "approver": "board" }
      ]
    },
    "data_privacy": {
      "regulation": "DPDP",
      "pseudonymization_required": true,
      "retention_limits": {
        "employee_data_years": 3,
        "financial_records_years": 8,
        "tax_records_years": 8
      }
    }
  },

  "legal_entities": {
    "entity_types": [
      { "code": "PvtLtd", "name": "Private Limited Company", "name_en": "Private Limited Company", "weight": 0.45 },
      { "code": "Ltd", "name": "Public Limited Company", "name_en": "Public Limited Company", "weight": 0.15 },
