    ],
    "minimum_wage": { "hourly": 11.44, "currency": "GBP", "effective_date": "2024-04-01" },
    "working_hours": {
      "standard_weekly": 37.5,
      "max_daily": 0.0,
      "statutory_annual_leave_days": 28,
      "common_annual_leave_days": 28
    },
    "thirteenth_month": false,
    "severance": {
      "statutory": true,
      "formula": "weeks_pay * years_of_service (capped)"
    }
  },

