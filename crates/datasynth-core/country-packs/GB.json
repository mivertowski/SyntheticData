    "audit_framework": "isa",
    "regulatory": {
      "sox_applicable": false,
      "local_regulations": ["Companies Act 2006", "FRS 102"],
      "filing_requirements": [
        { "name": "Annual Accounts", "name_en": "Annual Accounts", "deadline_months_after_ye": 9 },
        { "name": "Corporation Tax Return", "name_en": "Corporation Tax Return", "deadline_months_after_ye": 12 }
      ]
    }
  },

  "payroll": {
    "pay_frequency": "monthly",
    "currency": "GBP",
    "statutory_deductions": [
      { "code": "PAYE", "name": "Pay As You Earn", "name_en": "Income Tax", "type": "progressive", "rate": 0.0 },
      { "code": "NI_EE", "name": "National Insurance (Employee)", "name_en": "National Insurance", "type": "percentage", "rate": 0.08 }
