  "tax": {
    "corporate_income_tax": {
      "standard_rate": 0.25,
      "trade_tax_rate": 0.0,
      "solidarity_surcharge": 0.0,
      "effective_combined_rate": 0.25,
      "small_business_threshold": 50000.0
    },
    "vat": {
      "standard_rate": 0.20,
      "reduced_rates": [
        { "rate": 0.05, "label": "reduced", "applies_to": ["home_energy", "children_car_seats", "sanitary_products"] }
      ],
      "zero_rated": ["food", "children_clothing", "books", "newspapers"],
      "exempt": ["financial_services", "insurance", "education", "healthcare"],
      "registration_threshold": 85000.0,
      "filing_frequency": "quarterly",
      "reverse_charge_applicable": true
    },
    "withholding_tax": {
      "dividends_domestic": 0.0,
      "dividends_foreign_default": 0.0,
      "interest": 0.20,
      "royalties": 0.20,
      "services": 0.0
    },
    "payroll_tax": {
      "income_tax_brackets": [
        { "up_to": 12570, "rate": 0.0 },
        { "up_to": 50270, "rate": 0.20 },
        { "up_to": 125140, "rate": 0.40 },
        { "above": 125140, "rate": 0.45 }
      ],
      "social_security": {
        "national_insurance": {
          "employee_rate": 0.08,
          "employer_rate": 0.138,
          "primary_threshold": 12570,
          "upper_earnings_limit": 50270
        }
      },
      "church_tax_rate": 0.0
    },
    "transfer_pricing": {
      "documentation_required": true,
      "methods": ["CUP", "RPM", "CPLM", "TNMM", "PSM"],
      "safe_harbor_rules": false
    },
    "subnational": []
  },

  "address": {
    "format_template": "{building_number} {street}\n{city}\n{postal_code}",
    "components": {
      "street_names": [
        "High Street", "Church Road", "Station Road", "Victoria Road",
        "Mill Lane", "King Street", "Queen Street", "Park Road",
        "London Road", "Manor Road"
      ],
      "city_names": [
        "London", "Birmingham", "Manchester", "Leeds", "Glasgow",
        "Liverpool", "Bristol", "Sheffield", "Edinburgh", "Cardiff"
      ],
      "state_names": [
        "England", "Scotland", "Wales", "Northern Ireland"
      ],
      "state_codes": ["ENG", "SCT", "WLS", "NIR"]
    },
    "postal_code": {
      "format": "AN NAA",
      "regex": "^[A-Z]{1,2}[0-9][0-9A-Z]? [0-9][A-Z]{2}$",
      "ranges": []
    },
    "building_number": {
      "format": "numeric",
      "range": [1, 200]
    },
    "country_calling_code": "+44"
  },

  "phone": {
    "country_calling_code": "+44",
    "formats": {
      "landline": "+44-{area_code}-{subscriber}",
      "mobile": "+44-7{n3}-{n6}",
      "freephone": "+44-800-{n7}"
    },
    "area_codes": ["20", "121", "131", "141", "151", "161", "113", "114", "117", "29"],
    "subscriber_length": { "min": 7, "max": 8 },
    "display_format": "0{area_code} {subscriber}"
  },

  "banking": {
    "account_format": "both",
    "iban": {
      "country_prefix": "GB",
      "length": 22,
      "bban_structure": "{sort_code:6}{account_number:8}",
      "check_digit_algorithm": "mod97"
    },
    "domestic_format": {
      "routing_number_length": 6,
      "account_number_length": 8,
      "format_template": "{sort_code} / {account_number}"
    },
    "bank_names": [
      "HSBC Holdings", "Barclays", "Lloyds Banking Group",
      "NatWest Group", "Standard Chartered", "Santander UK"
    ],
    "swift_prefix": "GB",
    "payment_systems": ["BACS", "CHAPS", "Faster Payments"],
    "settlement_rules": {
      "domestic_transfer_days": 0,
      "international_transfer_days": 2,
      "wire_cutoff_time": "15:30",
      "direct_debit_lead_days": 3
    },
    "kyc_requirements": {
      "id_document_types": ["Passport", "Driving Licence", "Biometric Residence Permit"],
      "pep_screening_required": true,
      "beneficial_ownership_threshold": 0.25,
      "enhanced_due_diligence_triggers": ["high_risk_country", "pep", "complex_structure"]
    }
  },

  "business_rules": {
    "invoice": {
      "numbering_format": "INV-{YYYY}-{SEQ:6}",
      "mandatory_fields": ["company_number", "vat_number", "invoice_number", "date"],
      "retention_years": 6,
      "electronic_invoice_mandatory": false,
      "e_invoice_format": "UBL"
    },
    "payment_terms": {
      "default_days": 30,
      "common_terms": [14, 30, 60],
      "early_payment_discount": { "common_rate": 0.025, "common_days": 10 },
      "late_payment_interest": { "statutory_rate": 0.08, "base_rate_reference": "Bank of England" }
    },
    "approval_thresholds": {
      "currency": "GBP",
      "levels": [
        { "up_to": 5000, "approver": "team_lead" },
        { "up_to": 25000, "approver": "department_head" },
        { "up_to": 100000, "approver": "director" },
        { "above": 100000, "approver": "board" }
      ]
    },
    "data_privacy": {
      "regulation": "UK GDPR",
      "pseudonymization_required": true,
      "retention_limits": {
        "employee_data_years": 6,
        "financial_records_years": 6,
        "tax_records_years": 6
      }
    }
  },

  "legal_entities": {
    "entity_types": [
      { "code": "Ltd", "name": "Private Limited Company", "name_en": "Private Limited Company", "weight": 0.50 },
      { "code": "plc", "name": "Public Limited Company", "name_en": "Public Limited Company", "weight": 0.15 },
      { "code": "LLP", "name": "Limited Liability Partnership", "name_en": "Limited Liability Partnership", "weight": 0.20 },
