      "name": "National Insurance Number",
      "format": "AANNNNNNA",
      "regex": "^[A-Z]{2}[0-9]{6}[A-D]$"
    },
    "vat_id_format": {
      "name": "VAT Registration Number",
      "prefix": "GB",
      "format": "GB NNN NNNN NN",
      "regex": "^GB[0-9]{9}$"
    },
    "registration_authority": "Companies House",
    "registration_format": "{NNNNNNNN}"
  },

  "accounting": {
    "framework": "ifrs",
    "secondary_framework": "local_gaap",
    "local_gaap_name": "FRS 102",
    "chart_of_accounts": {
      "standard": "generic",
      "numbering_length": 4,
      "account_ranges": {}
