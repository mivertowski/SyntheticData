  "holidays": {
    "calendar_type": "gregorian",
    "fixed": [
      { "name": "New Year's Day", "name_en": "New Year's Day", "month": 1, "day": 1, "activity_multiplier": 0.02, "observe_weekend_rule": true },
      { "name": "Christmas Day", "name_en": "Christmas Day", "month": 12, "day": 25, "activity_multiplier": 0.02, "observe_weekend_rule": true },
      { "name": "Boxing Day", "name_en": "Boxing Day", "month": 12, "day": 26, "activity_multiplier": 0.02, "observe_weekend_rule": true }
    ],
    "easter_relative": [
      { "name": "Good Friday", "name_en": "Good Friday", "offset_days": -2, "activity_multiplier": 0.02 },
      { "name": "Easter Monday", "name_en": "Easter Monday", "offset_days": 1, "activity_multiplier": 0.02 }
    ],
    "nth_weekday": [
      { "name": "Early May Bank Holiday", "name_en": "Early May Bank Holiday", "month": 5, "weekday": "monday", "occurrence": 1, "activity_multiplier": 0.02 }
    ],
    "last_weekday": [
