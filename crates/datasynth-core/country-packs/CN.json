    "industry_words": {
      "manufacturing": ["制造", "机械", "精密", "金属", "科技"],
      "services": ["服务", "咨询", "物流", "贸易"],
      "technology": ["科技", "信息", "电子", "软件"],
      "supplies": ["商贸", "物资", "供应"]
