  },

  "document_texts": {
    "purchase_order": {
      "header_templates": [
        "采购订单 {po_number} — {vendor_name}",
        "框架合同 {contract_ref} 采购单"
      ],
      "line_descriptions": [
        "按规格交付 {material}",
