{
  "schema_version": "1.0",
  "country_code": "CN",
  "country_name": "China",
  "region": "APAC",

  "locale": {
    "language_code": "zh",
    "language_name": "Chinese",
    "default_currency": "CNY",
    "currency_symbol": "¥",
    "currency_decimal_places": 2,
    "number_format": {
      "decimal_separator": ".",
      "thousands_separator": ",",
      "grouping": [3]
    },
    "date_format": {
      "short": "YYYY-MM-DD",
      "long": "YYYY年MM月DD日",
      "iso": "YYYY-MM-DD"
    },
    "default_timezone": "Asia/Shanghai",
    "weekend_days": ["Saturday", "Sunday"],
    "fiscal_year": {
      "start_month": 1,
      "start_day": 1,
      "variant": "calendar"
    }
  },

